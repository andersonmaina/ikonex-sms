<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Class Performance Report</title>
  <style>
    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: #333;
      padding: 20px;
      margin: 0;
    }
    .header {
      text-align: center;
      border-bottom: 2px solid #1a365d;
      padding-bottom: 20px;
      margin-bottom: 30px;
    }
    .header h1 {
      margin: 0;
      color: #1a365d;
      font-size: 28px;
    }
    .header p {
      margin: 5px 0 0;
      color: #666;
      font-size: 16px;
    }
    .info-section {
      margin-bottom: 30px;
    }
    .info-section h2 {
      font-size: 20px;
      color: #1a365d;
      border-bottom: 1px solid #ddd;
      padding-bottom: 5px;
    }
    .metrics {
      display: flex;
      justify-content: space-between;
      margin-bottom: 30px;
      flex-wrap: wrap;
    }
    .metric-card {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      padding: 15px;
      width: 22%;
      text-align: center;
      box-sizing: border-box;
      margin-bottom: 15px;
    }
    .metric-title {
      font-size: 12px;
      text-transform: uppercase;
      color: #64748b;
      margin-bottom: 8px;
    }
    .metric-value {
      font-size: 24px;
      font-weight: bold;
      color: #1a365d;
    }
    .distribution {
      margin-top: 30px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
    }
    th, td {
      border: 1px solid #e2e8f0;
      padding: 12px;
      text-align: left;
    }
    th {
      background-color: #f1f5f9;
      color: #1a365d;
      font-weight: bold;
    }
    .footer {
      margin-top: 50px;
      text-align: center;
      font-size: 12px;
      color: #94a3b8;
    }
  </style>
</head>
<body>

  <div class="header">
    <h1>Ikonex Academy</h1>
    <p>Class Performance Analytics Report</p>
  </div>

  <div class="info-section">
    <h2>Report Details</h2>
    <p><strong>Stream:</strong> <%= streamName %></p>
    <p><strong>Generated On:</strong> <%= generatedDate %></p>
  </div>

  <div class="metrics">
    <div class="metric-card">
      <div class="metric-title">Average Score</div>
      <div class="metric-value"><%= avgScore %>%</div>
    </div>
    <div class="metric-card">
      <div class="metric-title">Passed Assessments</div>
      <div class="metric-value"><%= passed %></div>
    </div>
    <div class="metric-card">
      <div class="metric-title">Failed Assessments</div>
      <div class="metric-value"><%= failed %></div>
    </div>
    <div class="metric-card">
      <div class="metric-title">Total Assessments</div>
      <div class="metric-value"><%= totalAssessments %></div>
    </div>
  </div>

  <div class="info-section distribution">
    <h2>Grade Distribution</h2>
    <table>
      <thead>
        <tr>
          <th>Grade</th>
          <th>Number of Grades</th>
        </tr>
      </thead>
      <tbody>
        <% Object.keys(distribution).forEach(function(grade) { %>
          <tr>
            <td><strong><%= grade %></strong></td>
            <td><%= distribution[grade] %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="footer">
    <p>This is an official document generated by the Ikonex Academy Management System.</p>
  </div>

</body>
</html>
